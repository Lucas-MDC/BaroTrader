# Copy this file to .env for local Docker-first development.
# Exported shell variables override these defaults.

# Application runtime
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000

# Database host/port consumed by app and migration containers in Compose.
DB_HOST=db
DB_PORT=5432

# Runtime/provisioning admin
BAROTRADER_DB_ADMIN_DB=postgres
BAROTRADER_DB_ADMIN_USER=postgres
BAROTRADER_DB_ADMIN_PASSWORD=postgres

# Runtime application role
RUNTIME_DB=barotrader_db
RUNTIME_USER=barotrader_runtime
RUNTIME_PASSWORD=barotrader_runtime_password

# Migration role
MIGRATION_DB=barotrader_db
MIGRATION_USER=barotrader_migrator
MIGRATION_PASSWORD=barotrader_migrator_password

# Local test admin/base stack
TEST_DB=postgres
TEST_USER=postgres
TEST_PASSWORD=postgres

# Shared app controls
DB_BASE_ROLE=base_role_op
HASH_PEPPER=dev_hash_pepper
REGISTER_MIN_DELAY_MS=1000

# Manual destructive tooling only
DB_ALLOW_DESTRUCTIVE=NO
DB_DESTRUCTIVE_CONFIRM=barotrader_db

# Local integration-test debugging only
TEST_KEEP_DB=0
