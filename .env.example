# PostgreSQL Connection Configuration
# Copy this file to .env and fill in the values

# Host and port for PostgreSQL server
HOST=localhost
PORT=5432

# Runtime application user (DML only)
DB_DBNAME=barotrader_db
DB_USER=app_runtime
DB_PASS=app_runtime_password

# Migrator user (DDL/DCL)
MIGRATION_DB=barotrader_db
MIGRATION_USER=db_migrator
MIGRATION_PASS=db_migrator_password

# Derived connection strings (dotenv-expand supports interpolation)
# DATABASE_URL=postgres://${DB_USER}:${DB_PASS}@${HOST}:${PORT}/${DB_DBNAME}
# MIGRATIONS_DATABASE_URL=postgres://${MIGRATION_USER}:${MIGRATION_PASS}@${HOST}:${PORT}/${MIGRATION_DB}

# Optional: base role used for grants (defaults to base_role_op)
DB_BASE_ROLE=base_role_op

# Environment and destructive safety gates
APP_ENV=development
# DB_ALLOW_DESTRUCTIVE must be YES and DB_DESTRUCTIVE_CONFIRM must match the DB name
DB_ALLOW_DESTRUCTIVE=NO
DB_DESTRUCTIVE_CONFIRM=barotrader_db

# Password hashing
HASH_PEPPER=your_hash_pepper

# Registration controls
REGISTER_MIN_DELAY_MS=1000
