{
  "name": "barotrader",
  "version": "1.0.0",
  "description": "BaroTrader application",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --selectProjects integration",
    "test:integration:debug": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --selectProjects integration --runInBand",
    "test:unit": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --selectProjects unit",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage --runInBand --verbose",
    "db:setup": "node db/engine/main.js setup",
    "db:migrate": "node db/engine/main.js migrate",
    "db:seed": "node db/engine/main.js seed",
    "db:cleanup": "node db/engine/main.js cleanup",
    "db:test-sqlite": "node src/utils/database_sqlite.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lucas-MDC/BaroTrader.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Lucas-MDC/BaroTrader/issues"
  },
  "homepage": "https://github.com/Lucas-MDC/BaroTrader#readme",
  "dependencies": {
    "dotenv": "^17.2.3",
    "dotenv-expand": "^10.0.0",
    "express": "^5.1.0",
    "pg-promise": "^12.3.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "node-pg-migrate": "^7.7.0",
    "supertest": "^6.3.4"
  }
}
