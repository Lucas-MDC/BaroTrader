{
  "name": "barotrader",
  "version": "1.0.0",
  "description": "BaroTrader application",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:up": "node scripts/dev.js up",
    "dev:up:bg": "node scripts/dev.js up -d",
    "dev:down": "node scripts/dev.js down",
    "dev:reset": "node scripts/dev.js reset",
    "dev:bootstrap": "node scripts/dev.js bootstrap",
    "dev:open": "node scripts/dev.js open",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate:env:runtime": "node scripts/validate-env.js runtime",
    "validate:env:test": "node scripts/validate-env.js test",
    "test": "node scripts/test.js all",
    "test:integration": "node scripts/test.js integration",
    "test:integration:debug": "node scripts/test.js integration:debug",
    "test:unit": "node scripts/test.js unit",
    "test:coverage": "node scripts/test.js coverage",
    "db:setup": "node db/engine/main.js setup",
    "db:migrate": "node db/engine/main.js migrate",
    "db:seed": "node db/engine/main.js seed",
    "db:cleanup": "node db/engine/main.js cleanup"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lucas-MDC/BaroTrader.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Lucas-MDC/BaroTrader/issues"
  },
  "homepage": "https://github.com/Lucas-MDC/BaroTrader#readme",
  "dependencies": {
    "dotenv": "^17.2.3",
    "dotenv-expand": "^10.0.0",
    "express": "^5.1.0",
    "pg-promise": "^12.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "node-pg-migrate": "^7.7.0",
    "supertest": "^6.3.4"
  }
}
